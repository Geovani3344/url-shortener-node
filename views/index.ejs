<!DOCTYPE html>
<html lang="Pt-Br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title> Encurtador de URLs</title>
</head>
<body>
    <!-- Formulario simples para o usuario inserir a URL e enviar pro backend encurtar -->
    <form action="/shorten" method="POST">
        <input type="text" name="originalUrl" placeholder="Cole sua URL aqui" required>
        <button type="submit">Encurtar</button>  
    </form>
</body>
</html>